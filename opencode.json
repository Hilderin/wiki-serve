{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "wiki-serve": {
      "type": "local",
      "command": [
        "uv", "run", "wiki-serve", "bridge"
      ],
      "enabled": true,
      "environment": {
        "WIKI_INCLUDE": "./wiki",
        "WIKI_DATA_DIR": "./.wiki-index",
        "WIKI_HOST": "127.0.0.1",
        "WIKI_PORT": "8765",
        "WIKI_WATCH": "true",
        "WIKI_REINDEX_ON_START": "true"
      }
    }
  }
}
